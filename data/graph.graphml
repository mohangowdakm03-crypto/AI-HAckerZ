<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd"><key id="d3" for="edge" attr.name="context" attr.type="string"/>
<key id="d2" for="edge" attr.name="relation_type" attr.type="string"/>
<key id="d1" for="node" attr.name="description" attr.type="string"/>
<key id="d0" for="node" attr.name="entity_type" attr.type="string"/>
<graph edgedefault="directed"><node id="PUMP-101A">
  <data key="d0">EQUIPMENT</data>
  <data key="d1">Primary cooling water pump for the reactor system. Rated at 500 GPM at 75 PSI.</data>
</node>
<node id="PUMP-101B">
  <data key="d0">EQUIPMENT</data>
  <data key="d1">Standby redundant cooling pump. Automatically engages on PUMP-101A failure.</data>
</node>
<node id="VALVE-204">
  <data key="d0">EQUIPMENT</data>
  <data key="d1">Motorized gate valve regulating intake flow to the reactor cooling loop.</data>
</node>
<node id="VALVE-205">
  <data key="d0">EQUIPMENT</data>
  <data key="d1">Bypass valve for emergency flow rerouting during scheduled maintenance.</data>
</node>
<node id="HEAT-EXCHANGER-01">
  <data key="d0">EQUIPMENT</data>
  <data key="d1">Shell-and-tube heat exchanger transferring heat from reactor coolant to secondary loop.</data>
</node>
<node id="TEMP-SENS-08">
  <data key="d0">SENSOR</data>
  <data key="d1">PT100 RTD sensor monitoring casing temperature of PUMP-101A. Range: 0-150°C.</data>
</node>
<node id="PRESS-SENS-12">
  <data key="d0">SENSOR</data>
  <data key="d1">Differential pressure sensor across the cooling loop. Triggers alarm below 30 PSI.</data>
</node>
<node id="FLOW-METER-03">
  <data key="d0">SENSOR</data>
  <data key="d1">Electromagnetic flow meter measuring volumetric flow rate in the main cooling line.</data>
</node>
<node id="VIBRATION-SENS-07">
  <data key="d0">SENSOR</data>
  <data key="d1">Accelerometer detecting abnormal vibration on PUMP-101A bearing assembly.</data>
</node>
<node id="EMERGENCY-SHUTDOWN-01">
  <data key="d0">PROCEDURE</data>
  <data key="d1">ESD protocol SOP-ESD-01: isolates reactor coolant loop within 30 seconds of critical alarm.</data>
</node>
<node id="PREVENTIVE-MAINT-PM03">
  <data key="d0">PROCEDURE</data>
  <data key="d1">Quarterly bearing lubrication and seal inspection for all centrifugal pumps.</data>
</node>
<node id="OVERHEATING-RISK">
  <data key="d0">HAZARD</data>
  <data key="d1">Occurs when pump casing temperature exceeds 85°C. Risk of seal failure and coolant leak.</data>
</node>
<node id="CAVITATION-RISK">
  <data key="d0">HAZARD</data>
  <data key="d1">Low suction pressure causes vapour bubble formation, leading to impeller erosion.</data>
</node>
<node id="ISO-45001-SAFETY">
  <data key="d0">COMPLIANCE_STANDARD</data>
  <data key="d1">ISO 45001:2018 Occupational Health and Safety Management System standard.</data>
</node>
<node id="IEC-61511-FSS">
  <data key="d0">COMPLIANCE_STANDARD</data>
  <data key="d1">IEC 61511 Functional Safety Standard for Safety Instrumented Systems (SIS).</data>
</node>
<edge source="PUMP-101A" target="VALVE-204">
  <data key="d2">CONNECTED_TO</data>
  <data key="d3">PUMP-101A discharge connects directly to VALVE-204 which controls flow into the reactor cooling loop.</data>
</edge>
<edge source="PUMP-101A" target="PUMP-101B">
  <data key="d2">HAS_REDUNDANCY</data>
  <data key="d3">PUMP-101B serves as the automatic standby redundancy unit for PUMP-101A.</data>
</edge>
<edge source="PUMP-101B" target="VALVE-205">
  <data key="d2">CONNECTED_TO</data>
  <data key="d3">Standby pump PUMP-101B routed through bypass VALVE-205 for seamless failover.</data>
</edge>
<edge source="VALVE-204" target="HEAT-EXCHANGER-01">
  <data key="d2">FEEDS_INTO</data>
  <data key="d3">Regulated coolant flow from VALVE-204 enters the primary side of HEAT-EXCHANGER-01.</data>
</edge>
<edge source="TEMP-SENS-08" target="PUMP-101A">
  <data key="d2">MONITORS</data>
  <data key="d3">TEMP-SENS-08 continuously monitors casing temperature of PUMP-101A, triggering alarm at 85°C.</data>
</edge>
<edge source="TEMP-SENS-08" target="OVERHEATING-RISK">
  <data key="d2">TRIGGERS</data>
  <data key="d3">A reading above 85°C from TEMP-SENS-08 classifies the operating state as OVERHEATING-RISK.</data>
</edge>
<edge source="TEMP-SENS-08" target="IEC-61511-FSS">
  <data key="d2">GOVERNED_BY</data>
  <data key="d3">TEMP-SENS-08 is part of the Safety Instrumented System and governed by IEC 61511 SIL-2.</data>
</edge>
<edge source="PRESS-SENS-12" target="PUMP-101A">
  <data key="d2">MONITORS</data>
  <data key="d3">Differential pressure sensor detects suction head loss indicative of cavitation onset.</data>
</edge>
<edge source="PRESS-SENS-12" target="CAVITATION-RISK">
  <data key="d2">TRIGGERS</data>
  <data key="d3">Suction pressure drop below threshold detected by PRESS-SENS-12 raises CAVITATION-RISK alert.</data>
</edge>
<edge source="PRESS-SENS-12" target="IEC-61511-FSS">
  <data key="d2">GOVERNED_BY</data>
  <data key="d3">PRESS-SENS-12 is classified as a Safety Instrumented Function (SIF) under IEC 61511 SIL-2.</data>
</edge>
<edge source="FLOW-METER-03" target="VALVE-204">
  <data key="d2">MONITORS</data>
  <data key="d3">Flow meter verifies that VALVE-204 is delivering the required volumetric flow to the cooling loop.</data>
</edge>
<edge source="VIBRATION-SENS-07" target="PUMP-101A">
  <data key="d2">MONITORS</data>
  <data key="d3">Vibration sensor detects early-stage bearing wear on PUMP-101A to enable predictive maintenance.</data>
</edge>
<edge source="EMERGENCY-SHUTDOWN-01" target="ISO-45001-SAFETY">
  <data key="d2">GOVERNED_BY</data>
  <data key="d3">The ESD procedure SOP-ESD-01 is authored and audited in compliance with ISO 45001:2018.</data>
</edge>
<edge source="PREVENTIVE-MAINT-PM03" target="PUMP-101A">
  <data key="d2">GOVERNS</data>
  <data key="d3">PM03 schedule mandates quarterly inspection and bearing lubrication for PUMP-101A.</data>
</edge>
<edge source="PREVENTIVE-MAINT-PM03" target="PUMP-101B">
  <data key="d2">GOVERNS</data>
  <data key="d3">PM03 schedule equally applies to standby pump PUMP-101B to ensure failover readiness.</data>
</edge>
<edge source="OVERHEATING-RISK" target="EMERGENCY-SHUTDOWN-01">
  <data key="d2">INITIATES</data>
  <data key="d3">Detection of OVERHEATING-RISK automatically initiates the EMERGENCY-SHUTDOWN-01 ESD sequence.</data>
</edge>
<edge source="CAVITATION-RISK" target="EMERGENCY-SHUTDOWN-01">
  <data key="d2">INITIATES</data>
  <data key="d3">Sustained cavitation triggers EMERGENCY-SHUTDOWN-01 to prevent catastrophic impeller failure.</data>
</edge>
</graph></graphml>